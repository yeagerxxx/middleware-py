# FastAPI
APP_ENV=development

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://middleware:middleware@localhost:5432/middleware

# Redis
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=1800

# GLPI
GLPI_URL=https://glpi.example.com/apirest.php
GLPI_APP_TOKEN=seu-app-token
GLPI_USER_TOKEN=seu-user-token

# Evolution API
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=sua-instancia
